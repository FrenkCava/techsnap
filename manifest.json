{
  "manifest_version": 3,
  "name": "TechSnap",
  "version": "5.1.1",
  "description": "Registra video tutorial con sottotitoli VTT multilingua. Finestra persistente con dettatura vocale.",
  "permissions": [
    "activeTab",
    "tabCapture",
    "downloads",
    "alarms",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
